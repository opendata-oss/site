---
import Base from "../../layouts/Base.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts
    .filter((post) => !post.data.draft)
    .map((post) => ({
      params: { slug: post.id },
      props: { post },
    }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Base
  title={`${post.data.title} | OpenData`}
  description={post.data.description}
  ogImage={`/blog/${post.id}/og.png`}
>
  <div
    class="bg-white min-h-screen flex flex-col items-center gap-6 px-4 pt-24 pb-12"
  >
    <article class="font-mono text-slate-700 max-w-2xl w-full space-y-6">
      <header class="space-y-2">
        <h1 class="text-2xl text-slate-900">{post.data.title}</h1>
        <div class="flex items-center gap-3 text-sm text-slate-400">
          <time>{post.data.date.toISOString().slice(0, 10)}</time>
          <span>&middot;</span>
          <span>{post.data.author}</span>
        </div>
        {post.data.tags.length > 0 && (
          <div class="flex gap-2">
            {post.data.tags.map((tag: string) => (
              <span class="text-xs text-slate-400 border border-slate-200 rounded-full px-2 py-0.5">
                {tag}
              </span>
            ))}
          </div>
        )}
      </header>

      <div class="prose-opendata">
        <Content />
      </div>
    </article>
    <a
      href="/blog"
      class="font-mono text-sm text-slate-500 hover:text-slate-900 underline underline-offset-4 transition-colors"
    >
      &larr; all posts
    </a>
  </div>
</Base>
