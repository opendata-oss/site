---
import Base from "../../layouts/Base.astro";
import PostToc from "../../components/PostToc.astro";
import Tldr from "../../components/Tldr.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts
    .filter((post) => !post.data.draft)
    .map((post) => ({
      params: { slug: post.id },
      props: { post },
    }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

// tags[0] is the product the post is about; it labels the gutter and keys the
// end-of-post terminal.
const tags: string[] = post.data.tags ?? [];
const productKey = tags[0] ?? "post";
const dateStr = post.data.date.toISOString().slice(0, 10);

// Products that have a get-started path. `install: null` means embedded (no
// install step). Posts whose first tag isn't a product (e.g. manifesto) skip
// the strip entirely.
const PRODUCTS: Record<string, { name: string; install: string | null; href: string }> = {
  log: { name: "Log", install: "log", href: "/docs/log/quickstart" },
  timeseries: { name: "Timeseries", install: "timeseries", href: "/docs/timeseries/quickstart" },
  vector: { name: "Vector", install: "vector", href: "/docs/vector/quickstart" },
  buffer: { name: "Buffer", install: null, href: "/docs/buffer" },
};
const product = PRODUCTS[productKey] ?? null;
---

<Base
  title={`${post.data.title} | OpenData`}
  description={post.data.description}
  ogImage={`/blog/${post.id}/og.png`}
>
  <PostToc headings={headings} />
  <div class="bg-white min-h-screen pt-10 md:pt-14 pb-16">
    <div class="lower">
      <!-- Header row: product label in the gutter, title + meta bracketed by
           the shared section-label rule (same device as the home page + index). -->
      <div class="lower-row">
        <div class="lower-label"><span>{productKey}</span></div>
        <div class="lower-content">
          <h1 class="posthead-title">{post.data.title}</h1>
          <div class="posthead-meta">
            <time class="tabular-nums">{dateStr}</time>
            <span>&middot;</span>
            <span>{post.data.author}</span>
          </div>
        </div>
      </div>

      <!-- Body row: aligned under the header's content column, no gutter rule. -->
      <div class="lower-row post-bodyrow">
        <div class="post-gutter-empty" aria-hidden="true"></div>
        <article class="post post-bodycol text-[#444]">
          <div class="prose-opendata">
            <Content components={{ Tldr }} />
          </div>
        </article>
      </div>

      {product && (
        <!-- Get Started: its own bracketed section, mirroring the home page —
             "GET STARTED" in the gutter, the product as the selected window tab. -->
        <div class="lower-row">
          <div class="lower-label"><span>Get</span> <span>Started</span></div>
          <div class="lower-content">
            <aside class="endterm">
              <div class="endterm-bar">
                <span class="endterm-dots" aria-hidden="true"><i></i><i></i><i></i></span>
                <div class="endterm-tabs"><span class="endterm-tab">{productKey}</span></div>
              </div>
              <div class="endterm-body">
                {product.install ? (
                  <>
                    <pre class="endterm-cmd"><span class="endterm-prompt">$</span> curl -fsSL https://www.opendata.dev/install.sh | sh -s -- {product.install}</pre>
                    <span class="endterm-out">&rarr; installed opendata-{product.install}</span>
                    <a class="endterm-out endterm-link" href={product.href}>&rarr; read the {product.name} quickstart</a>
                  </>
                ) : (
                  <>
                    <pre class="endterm-cmd endterm-comment"># {product.name} is an embedded library &mdash; no install needed</pre>
                    <a class="endterm-out endterm-link" href={product.href}>&rarr; read the {product.name} docs</a>
                  </>
                )}
              </div>
            </aside>
          </div>
        </div>
      )}

      <!-- Footer nav row: aligned with the body column, no gutter rule. -->
      <div class="lower-row post-bodyrow">
        <div class="post-gutter-empty" aria-hidden="true"></div>
        <div class="post-bodycol">
          <div class="post-nav">
            <a href="/blog" class="post-nav-link">&larr; all posts</a>
            <a
              href="/rss.xml"
              class="post-nav-rss"
              aria-label="Subscribe via RSS"
              title="Subscribe via RSS"
            >
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19 7.38 20 6.18 20C5 20 4 19 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1Z" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</Base>

<style>
  /* Title + meta sit in the shared .lower-content (bracketed by the gutter
     rule); the product label lives in the .lower-label gutter beside it. */
  .posthead-title {
    font-family: var(--font-mono);
    font-size: clamp(22px, 4vw, 28px); font-weight: 700;
    letter-spacing: -0.5px; line-height: 1.18;
    color: #1a1a1a; margin: 0;
  }
  .posthead-meta {
    font-family: var(--font-mono);
    font-size: 12px; color: #9a9a9a;
    margin-top: 14px;
    display: flex; gap: 10px; align-items: center; flex-wrap: wrap;
  }
  /* The body continues the same content column, without the gutter rule. The
     shared adjacent-row rules (72px gap on desktop; a divider on mobile) are
     meant for separate sections, so neutralize them here. */
  .post-bodyrow {
    margin-top: 0 !important;
    border-top: 0 !important;
    padding-top: 0 !important;
  }
  .post-bodycol { padding-left: 56px; padding-top: 16px; min-width: 0; }
  @media (max-width: 900px) {
    .post-gutter-empty { display: none; }
    .post-bodycol { padding-left: 0; padding-top: 24px; }
  }

  /* End-of-post terminal — mirrors the home page install terminal: warm paper
     ground (minus the backdrop image), traffic-light window decor, and the
     product shown as the (only) selected tab. Sits in its own bracketed
     "GET STARTED" gutter section, like the home page get-started section. */
  .endterm {
    position: relative;
    border: 1px solid rgba(20, 24, 40, 0.12);
    box-shadow: 6px 6px 0 0 #d6d7d9;
    background: #f7f3ea;
    overflow: hidden;
  }
  .endterm-bar {
    display: flex; align-items: stretch; gap: 14px;
    padding: 0 12px;
    background: rgba(236, 231, 219, 0.55);
    border-bottom: 1px solid rgba(20, 24, 40, 0.12);
  }
  .endterm-dots { display: inline-flex; align-items: center; gap: 6px; flex: none; }
  .endterm-dots i { width: 11px; height: 11px; border-radius: 50%; }
  .endterm-dots i:nth-child(1) { background: #d98c7a; }
  .endterm-dots i:nth-child(2) { background: #d9c27a; }
  .endterm-dots i:nth-child(3) { background: #9fb08a; }
  /* Single product, shown as the selected tab (home page active-tab styling). */
  .endterm-tabs { display: flex; align-self: stretch; }
  .endterm-tab {
    display: flex; align-items: center;
    font-family: var(--font-mono); font-size: 12px; font-weight: 700;
    color: #4971ab;
    padding: 9px 14px;
    background: rgba(255, 255, 255, 0.55);
    border-left: 1px solid rgba(20, 24, 40, 0.1);
    border-right: 1px solid rgba(20, 24, 40, 0.1);
  }
  .endterm-body { padding: 22px 20px; }
  .endterm-cmd {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 13px; line-height: 1.6; color: #2a2a2a;
    white-space: pre-wrap; word-break: break-all;
  }
  .endterm-prompt { color: #4971ab; font-weight: 700; margin-right: 8px; }
  .endterm-out {
    display: block;
    font-family: var(--font-mono);
    font-size: 13px; line-height: 1.6; color: #6a6a6a; text-decoration: none;
  }
  .endterm-cmd + .endterm-out { margin-top: 8px; }
  .endterm-link { color: #4971ab; transition: color .15s ease; }
  .endterm-link:hover { color: #375481; text-decoration: underline; text-underline-offset: 2px; }
  .endterm-comment { color: #8a8a8a; font-style: italic; }

  /* Footer nav, left-aligned with the body. */
  .post-nav {
    display: flex; align-items: center; gap: 24px;
    margin-top: 44px;
    font-family: var(--font-mono); font-size: 14px;
  }
  .post-nav-link { color: #6a6a6a; text-decoration: underline; text-underline-offset: 4px; transition: color .15s ease; }
  .post-nav-link:hover { color: #4971ab; }
  .post-nav-rss { color: #9a9a9a; transition: color .15s ease; }
  .post-nav-rss:hover { color: #4971ab; }
</style>
