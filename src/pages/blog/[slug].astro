---
import Base from "../../layouts/Base.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts
    .filter((post) => !post.data.draft)
    .map((post) => ({
      params: { slug: post.id },
      props: { post },
    }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Base
  title={`${post.data.title} | OpenData`}
  description={post.data.description}
  ogImage={`/blog/${post.id}/og.png`}
>
  <div
    class="bg-white min-h-screen flex flex-col items-center gap-6 px-4 pt-24 pb-12"
  >
    <article class="post text-slate-700 max-w-2xl w-full space-y-6">
      <header class="space-y-3">
        <h1 class="text-2xl text-slate-900 font-bold">{post.data.title}</h1>
        <div class="flex items-center gap-3 text-sm text-slate-400">
          <time>{post.data.date.toISOString().slice(0, 10)}</time>
          <span>&middot;</span>
          <span>{post.data.author}</span>
        </div>
        {post.data.tags.length > 0 && (
          <div class="flex gap-2">
            {post.data.tags.map((tag: string) => (
              <span class="text-xs text-slate-400 border border-slate-200 rounded-full px-2 py-0.5">
                {tag}
              </span>
            ))}
          </div>
        )}
      </header>

      <div class="prose-opendata">
        <Content />
      </div>
    </article>
    <div class="flex items-center gap-6 font-mono text-sm">
      <a
        href="/blog"
        class="text-slate-500 hover:text-slate-900 underline underline-offset-4 transition-colors"
      >
        &larr; all posts
      </a>
      <a
        href="/rss.xml"
        class="text-slate-400 hover:text-slate-900 transition-colors"
        aria-label="Subscribe via RSS"
        title="Subscribe via RSS"
      >
        <svg
          class="w-4 h-4"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
        >
          <path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19 7.38 20 6.18 20C5 20 4 19 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1Z" />
        </svg>
      </a>
    </div>
  </div>
</Base>
