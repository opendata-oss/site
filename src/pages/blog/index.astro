---
import Base from "../../layouts/Base.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Base
  title="Blog | OpenData"
  description="Updates and insights from the OpenData project"
  ogImage="/images/opengraph.png"
>
  <div class="bg-white min-h-screen pt-10 md:pt-14">
    <!-- shared section-label gutter (.lower*) so the label inset matches the
         home page exactly; the RSS link stacks beneath the label. -->
    <div class="lower">
      <div class="lower-row">
        <div class="lower-label">
          <span>Blog</span>
          <a
            href="/rss.xml"
            class="blog-rss"
            aria-label="Subscribe via RSS"
            title="Subscribe via RSS"
          >
            <svg class="w-[18px] h-[18px] inline-block" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19 7.38 20 6.18 20C5 20 4 19 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1Z" />
            </svg>
          </a>
        </div>
        <div class="lower-content">
          {posts.length === 0 && <p class="blog-empty">No posts yet.</p>}

          <ul class="blog-list">
            {posts.map((post) => (
              <li>
                <a href={`/blog/${post.id}`} class="blog-item group">
                  <span class="blog-item-t">{post.data.title}</span>
                  <time class="blog-item-d">
                    {post.data.date.toISOString().slice(0, 10)}
                  </time>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </div>
</Base>

<style>
  /* RSS link sits beneath the "Blog" label in the gutter on desktop. Once the
     gutter stacks (≤900px, matching the shared .lower breakpoint) it moves
     inline, next to the label. */
  .blog-rss { display: block; margin-top: 12px; color: #9a9a9a; transition: color .15s ease; }
  .blog-rss:hover { color: #4971ab; }
  @media (max-width: 900px) {
    .blog-rss { display: inline-block; margin-top: 0; margin-left: 12px; vertical-align: middle; }
  }
  .blog-empty { font-family: var(--font-mono); color: #9a9a9a; }

  .blog-list { list-style: none; margin: 0; padding: 0; }
  .blog-list li + li { border-top: 1px solid #ececec; }
  .blog-item {
    display: flex; align-items: baseline; justify-content: space-between; gap: 16px;
    padding: 13px 0;
  }
  .blog-item-t {
    font-family: var(--font-sans);
    font-size: 15px; color: #1a1a1a; transition: color .15s ease;
  }
  .blog-item:hover .blog-item-t { color: #4971ab; }
  .blog-item-d {
    font-family: var(--font-mono);
    font-size: 12px; color: #9a9a9a; flex: none;
    font-variant-numeric: tabular-nums;
  }
</style>
