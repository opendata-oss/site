---
import LandingLayout from '../layouts/LandingLayout.astro';
import Navbar from '../components/Navbar.astro';
import { diagramHTML, panelHTML } from '../components/family.data';

const GH = 'https://github.com/opendata-oss/opendata';
const DISCORD = 'https://discord.gg/CsAQJ2AJGU';

const initialDiagram = diagramHTML(0);
const initialPanel = panelHTML(0);
---

<LandingLayout
  title="OpenData — Open Source Object Store Native Databases"
  description="A family of open-source, object-store native databases that all run on the same storage engine built on SlateDB."
  ogImage="/images/opengraph.png"
>
  <div class="min-h-screen">
    <!-- announcement bar -->
    <a
      href="/blog/introducing-vector"
      class="block bg-[#eef2fb] border-b border-[#e3e8f3] py-[9px] text-center text-[12px] text-[#3a66d6] hover:bg-[#e6ecfb] transition-colors"
    >
      <b>NEW</b> &middot; Introducing OpenData Vector &rarr; object-store native similarity search
    </a>

    <Navbar />

    <!-- hero -->
    <div class="hero-wrap">
      <div class="hero-grid"></div>
      <div class="hero-inner max-w-[1180px] mx-auto px-5 sm:px-8 pt-[72px] pb-[80px] sm:pt-[96px] sm:pb-[104px] text-center">
        <h1 class="text-[34px] sm:text-[46px] leading-[1.1] font-bold tracking-[-1.5px]">One foundation.<br />Every database.</h1>
        <p class="max-w-[600px] mx-auto mt-[26px] text-[15px] leading-[1.65] text-[#5a5a5a]">
          A family of open-source databases that all run on the <b class="text-[#1a1a1a]">same object-storage engine</b> &mdash; so the more of them you adopt, the simpler and cheaper your whole stack gets.
        </p>
        <div class="flex flex-col sm:flex-row gap-[14px] justify-center mt-[34px]">
          <a href="#family" class="bg-[#1a1a1a] text-white text-[13px] font-medium px-[24px] py-[14px] rounded-[8px] hover:bg-black transition-colors">Explore the databases &darr;</a>
          <a href="/docs" class="bg-white text-[#1a1a1a] text-[13px] font-medium px-[24px] py-[14px] rounded-[8px] border border-[#d6d6d6] hover:border-[#1a1a1a] transition-colors">Read the docs</a>
        </div>
      </div>
    </div>

    <!-- interactive family diagram -->
    <div id="family" class="scroll-mt-24 bg-white">
      <div class="sec sec-family">
        <div class="abox">
          <span class="abox-title">the databases</span>
          <div class="lead">
            <div class="lead-h">Multiple databases, one storage engine</div>
            <p class="lead-p">All OpenData databases run on a shared storage foundation built on <a href="https://www.slatedb.io/" target="_blank" rel="noopener">SlateDB</a>.</p>
          </div>

          <div class="grid grid-cols-1 gap-10 lg:gap-12 lg:grid-cols-[max-content_1fr] lg:items-center mt-11">
            <div class="fam-diag overflow-x-auto">
              <pre
                id="family-diagram"
                class="m-0 select-none"
                style="font-family:'JetBrains Mono',ui-monospace,monospace;line-height:1;white-space:pre;display:inline-block;text-align:left"
                set:html={initialDiagram}
              />
            </div>
            <div id="family-panel" set:html={initialPanel} />
          </div>
        </div>
      </div>
    </div>

    <!-- three benefits -->
    <div class="sec sec-why">
      <div class="abox">
        <span class="abox-title">why opendata</span>
        <div class="grid gap-10 md:grid-cols-3">
          <div>
            <div class="bnum">01</div>
            <div class="text-[17px] font-bold mb-[10px]">Simpler to operate</div>
            <p class="text-[13px] leading-[1.65] text-[#6a6a6a]">One storage layer, one mental model. Learn it once and every database in the family works the same way.</p>
          </div>
          <div>
            <div class="bnum">02</div>
            <div class="text-[17px] font-bold mb-[10px]">Cheaper in aggregate</div>
            <p class="text-[13px] leading-[1.65] text-[#6a6a6a]">Pay object-storage prices instead of overprovisioned disks. Costs compound downward as you add more databases.</p>
          </div>
          <div>
            <div class="bnum">03</div>
            <div class="text-[17px] font-bold mb-[10px]">Impossible to outgrow</div>
            <p class="text-[13px] leading-[1.65] text-[#6a6a6a]">Capacity scales with your object store. No re-sharding, no migrations, no ceiling.</p>
          </div>
        </div>
      </div>
    </div>

    <!-- OSS strip -->
    <div class="bg-[#1a1a1a]">
      <div class="max-w-[1180px] mx-auto px-5 sm:px-8 py-[30px] flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
        <span class="text-[13px] text-white font-medium">Open-source &middot; contributors welcome</span>
        <div class="flex gap-[14px]">
          <a href={GH} target="_blank" rel="noopener" class="text-[12px] text-[#cfcfcf] border border-[#3a3a3a] rounded-[7px] px-[15px] py-[9px] hover:border-[#666] transition-colors">&#9733; Star on GitHub</a>
          <a href={DISCORD} target="_blank" rel="noopener" class="text-[12px] text-[#cfcfcf] border border-[#3a3a3a] rounded-[7px] px-[15px] py-[9px] hover:border-[#666] transition-colors">Join Discord</a>
        </div>
      </div>
    </div>
  </div>
</LandingLayout>

<style is:global>
  html { scroll-behavior: smooth; }
  @keyframes pulseBlink { 0%, 100% { opacity: 0.3 } 50% { opacity: 1 } }
  @keyframes famFadeUp { from { opacity: 0; transform: translateY(8px) } to { opacity: 1; transform: none } }
  .fam-anim { animation: pulseBlink 1.4s ease-in-out infinite; }

  /* Diagram: fixed 13px monospace on desktop; scales down to fit its container
     on narrow/stacked screens so the whole diagram is visible without scrolling. */
  #family-diagram { font-size: 13px; }
  @media (max-width: 1023px) {
    .fam-diag { container-type: inline-size; }
    #family-diagram { font-size: min(13px, 2.15cqi); }
  }

  /* Framed sections: double border with a title tab */
  .abox { position: relative; border: 3px double #d0d0d0; background: #fff; padding: 48px 32px 40px; }
  .abox-title { position: absolute; top: -13px; left: 22px; background: #fff; padding: 0 10px; font-family: var(--font-mono); font-size: 16px; font-weight: 700; letter-spacing: .3px; color: #3a66d6; }
  .sec { max-width: 1180px; margin-left: auto; margin-right: auto; padding-left: 24px; padding-right: 24px; }
  .sec-family { padding-top: 48px; padding-bottom: 64px; }
  .sec-why { padding-top: 12px; padding-bottom: 76px; }
  .lead { margin-bottom: 28px; }
  .lead-h { font-size: 26px; font-weight: 700; letter-spacing: -0.5px; }
  .lead-p { max-width: 560px; margin-top: 12px; font-size: 14px; line-height: 1.6; color: #6a6a6a; }

  /* Inline links in body copy read as links (accent blue + underline);
     scoped to paragraphs so nav/button anchors are unaffected. */
  p a { color: #3a66d6; text-decoration: underline; text-underline-offset: 2px; text-decoration-thickness: 1px; transition: color .15s ease; }
  p a:hover { color: #2a4fb0; }
  .bnum { font-size: 44px; font-weight: 700; color: #ececec; line-height: 1; letter-spacing: -1px; margin-bottom: 12px; }
  @media (max-width: 640px) { .abox { padding: 42px 20px 34px; } .sec { padding-left: 18px; padding-right: 18px; } }

  /* Hero with masked blue grid backdrop */
  .hero-wrap { position: relative; overflow: hidden; background: #fff; }
  .hero-grid {
    position: absolute; inset: 0; pointer-events: none;
    background-color: rgba(58, 102, 214, .04);
    background-image:
      linear-gradient(to right, rgba(40, 86, 200, .07) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(40, 86, 200, .07) 1px, transparent 1px);
    background-size: 38px 38px; background-position: center top;
    -webkit-mask-image: radial-gradient(115% 82% at 50% 46%, #000 0%, rgba(0, 0, 0, .4) 48%, transparent 74%);
    mask-image: radial-gradient(115% 82% at 50% 46%, #000 0%, rgba(0, 0, 0, .4) 48%, transparent 74%);
  }
  .hero-inner { position: relative; z-index: 1; }

  @media (prefers-reduced-motion: reduce) {
    html { scroll-behavior: auto; }
    .fam-anim { animation: none; }
  }
</style>

<script>
  import '../components/family.client.ts';
</script>
