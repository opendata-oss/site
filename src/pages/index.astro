---
import LandingLayout from '../layouts/LandingLayout.astro';
import Navbar from '../components/Navbar.astro';
import { diagramHTML, diagramHTMLHorizontal, panelsHTML, DEFAULT_SELECTION, databases } from '../components/family.data';

const GH = 'https://github.com/opendata-oss/opendata';
const DISCORD = 'https://discord.gg/CsAQJ2AJGU';

const initialDiagram = diagramHTML(DEFAULT_SELECTION);
const initialDiagramH = diagramHTMLHorizontal(DEFAULT_SELECTION);
const initialPanel = panelsHTML(DEFAULT_SELECTION);
---

<LandingLayout
    title="OpenData — Open Source and Object Store Native Databases"
  description="A family of open-source, object-store native databases built on SlateDB."
  ogImage="/images/opengraph.png"
>
  <div class="min-h-screen">
    <!-- announcement bar -->
    <a
      href="/blog/announcing-opendata-log"
      class="announce group flex items-center justify-center gap-[6px] bg-[#eef2fb] border-b border-[#e3e8f3] py-[9px] text-center text-[12px] text-[#4971ab] hover:bg-[#e6ecfb] transition-colors"
    >
      <span><b>NEW</b> &middot; Introducing OpenData Log &mdash; object-store native event streaming</span>
      <span class="announce-arrow font-semibold transition-transform group-hover:translate-x-[3px]">&rarr;</span>
    </a>

    <Navbar />

    <!-- hero -->
    <div class="hero-wrap">
      <div class="hero-inner max-w-[1280px] mx-auto px-5 sm:px-8 pt-[44px] pb-[40px] sm:pt-[60px] sm:pb-[48px] text-left">
        <p class="max-w-[600px] text-[15px] leading-[1.65] font-medium text-[#444]">
        OpenData is a family of open-source, object-native databases that reduces costs, simplifies operations and scales with ease.
        </p>
        <div class="flex flex-col sm:flex-row gap-[12px] justify-start mt-[20px]">
          <a href="#family" class="bg-[#1a1a1a] text-white text-[12px] font-medium px-[18px] py-[10px] hover:bg-black transition-colors">Explore the databases &darr;</a>
          <a href="/docs" class="bg-white text-[#1a1a1a] text-[12px] font-medium px-[18px] py-[10px] border border-[#d6d6d6] hover:border-[#1a1a1a] transition-colors">Read the docs</a>
        </div>
      </div>
    </div>

    <!-- interactive family diagram -->
    <div id="family" class="scroll-mt-24 bg-white">
      <div class="sec sec-family">
        <div class="abox abox-bg">
          <div class="float-card">
            <div class="fam-grid">
              <!-- Left column: heading + diagram. The heading lives in this
                   column (not above the grid) so the row spans the full card
                   height and the dialog can be centered against the whole card. -->
              <div class="fam-left">
                <div class="lead">
                  <div class="lead-h">Databases made simple</div>
                  <p class="lead-p">All OpenData systems are built on the same foundation so once you know how to operate the first, you know how to operate the rest.</p>
                </div>
                <div class="fam-diag">
                  <pre
                    id="family-diagram"
                    class="fam-pre fam-pre-v m-0 select-none"
                    style="font-family:'JetBrains Mono',ui-monospace,monospace;line-height:1;white-space:pre;text-align:left"
                    set:html={initialDiagram}
                  />
                  <pre
                    id="family-diagram-h"
                    class="fam-pre fam-pre-h m-0 select-none"
                    style="font-family:'JetBrains Mono',ui-monospace,monospace;line-height:1;white-space:pre;text-align:left"
                    set:html={initialDiagramH}
                  />
                </div>
              </div>
              <div id="family-panel" set:html={initialPanel} />
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- lower half: a left gutter of section labels runs alongside the
         remaining sections, divided from the content by a single vertical rule. -->
    <div class="lower">
      <!-- why opendata -->
      <div class="lower-row">
        <div class="lower-label"><span>Why</span> <span>OpenData</span></div>
        <div class="lower-content">
          <div class="max-w-[620px]">
          <p class="text-[15px] leading-[1.8] text-[#444] mb-5">Running production databases requires specialized expertise, which is why databases are expensive.</p>
          <p class="text-[15px] leading-[1.8] text-[#444] mb-8">Object storage promises to change that. It gives us durable, globally addressable storage that makes radically simpler database architectures possible. What's more, the engineering needed to use object storage optimally is substantially similar across databases. That's why every OpenData database shares:</p>

          <!-- the three pillars, broken out from the prose so the section reads as
               structured benefits rather than a floating paragraph. -->
          <div class="why-grid">
            <div class="why-pillar">
              <div class="why-pillar-n">01</div>
              <div class="why-pillar-h">Object native</div>
              <p class="why-pillar-p">Infinite storage with high durability and excellent unit economics.</p>
            </div>
            <div class="why-pillar">
              <div class="why-pillar-n">02</div>
              <div class="why-pillar-h">Common tooling</div>
              <p class="why-pillar-p">One operational model to learn with a common configuration.</p>
            </div>
            <div class="why-pillar">
              <div class="why-pillar-n">03</div>
              <div class="why-pillar-h">MIT licensed</div>
              <p class="why-pillar-p">Open formats and a permissive license prevent vendor lock-in.</p>
            </div>
          </div>

          <a href="/blog/manifesto" class="inline-flex items-center gap-1 text-[14px] font-medium text-[#4971ab] hover:text-[#375481] transition-colors">Read the manifesto &rarr;</a>
          </div>
        </div>
      </div>

      <!-- get started -->
      <div class="lower-row">
        <div class="lower-label"><span>Get</span> <span>Started</span></div>
        <div class="lower-content lower-content-last">
          <div class="term max-w-[620px]">
        <!-- pure-CSS tabs: hidden radios drive both the tab highlight and the
             visible command line via :checked sibling selectors -->
        <input class="term-radio" type="radio" name="term-tab" id="term-log" checked />
        <input class="term-radio" type="radio" name="term-tab" id="term-timeseries" />
        <input class="term-radio" type="radio" name="term-tab" id="term-vector" />
        <input class="term-radio" type="radio" name="term-tab" id="term-buffer" />

        <div class="term-bar">
          <span class="term-dots" aria-hidden="true"><i></i><i></i><i></i></span>
          <div class="term-tabs" role="tablist">
            <label class="term-tab" for="term-log">log</label>
            <label class="term-tab" for="term-timeseries">timeseries</label>
            <label class="term-tab" for="term-vector">vector</label>
            <label class="term-tab" for="term-buffer">buffer</label>
          </div>
        </div>

        <div class="term-body">
          <div class="term-block term-block-log">
            <pre class="term-cmd"><span class="term-prompt">$</span> curl -fsSL https://www.opendata.dev/install.sh | sh -s -- log</pre>
            <span class="term-out">&rarr; installed opendata-log</span>
            <a class="term-out term-link" href="/docs/log/quickstart">&rarr; read the log quickstart</a>
          </div>
          <div class="term-block term-block-timeseries">
            <pre class="term-cmd"><span class="term-prompt">$</span> curl -fsSL https://www.opendata.dev/install.sh | sh -s -- timeseries</pre>
            <span class="term-out">&rarr; installed opendata-timeseries</span>
            <a class="term-out term-link" href="/docs/timeseries/quickstart">&rarr; read the timeseries quickstart</a>
          </div>
          <div class="term-block term-block-vector">
            <pre class="term-cmd"><span class="term-prompt">$</span> curl -fsSL https://www.opendata.dev/install.sh | sh -s -- vector</pre>
            <span class="term-out">&rarr; installed opendata-vector</span>
            <a class="term-out term-link" href="/docs/vector/quickstart">&rarr; read the vector quickstart</a>
          </div>
          <div class="term-block term-block-buffer">
            <pre class="term-cmd term-comment"># Buffer is an embedded library &mdash; no install needed</pre>
            <a class="term-out term-link" href="/docs/buffer">&rarr; read the buffer docs</a>
          </div>
        </div>
          </div>
        </div>
      </div>
    </div>

    <!-- built on slatedb -->
    <div class="sec sec-slate">
      <div class="slate-row">
        <span class="slate-label">powered by</span>
        <a href="https://slatedb.io" target="_blank" rel="noopener" class="slate-logo-link">
          <img src="/images/slatedb-logo-full.svg" alt="SlateDB" class="slate-logo" />
        </a>
      </div>
    </div>

    <!-- footer -->
    <footer class="bg-white border-t border-[#ececec]">
      <div class="max-w-[1280px] mx-auto px-5 sm:px-8 py-[32px] flex flex-col gap-12 md:flex-row md:items-start md:justify-between">
        <!-- brand (left): logo + copyright -->
        <div>
          <img src="/images/logo.svg" alt="OpenData" class="h-5 w-auto" />
          <p class="mt-3 text-[12px] text-[#9a9a9a]">&copy; 2026 OpenData &middot; MIT licensed</p>
        </div>

        <!-- sitemap (right): tightly-packed link columns -->
        <div class="flex flex-wrap gap-x-12 gap-y-10">
          <!-- databases -->
          <div>
            <div class="text-[11px] font-semibold uppercase tracking-[0.6px] text-[#1a1a1a] mb-[14px]">Databases</div>
            <ul class="space-y-[10px]">
              {databases.map((d) => (
                <li><a href={`/docs/${d.key}`} class="text-[13px] text-[#6a6a6a] hover:text-[#1a1a1a] transition-colors">{d.name}</a></li>
              ))}
            </ul>
          </div>

          <!-- resources -->
          <div>
            <div class="text-[11px] font-semibold uppercase tracking-[0.6px] text-[#1a1a1a] mb-[14px]">Resources</div>
            <ul class="space-y-[10px]">
              <li><a href="/docs" class="text-[13px] text-[#6a6a6a] hover:text-[#1a1a1a] transition-colors">Docs</a></li>
              <li><a href="/blog" class="text-[13px] text-[#6a6a6a] hover:text-[#1a1a1a] transition-colors">Blog</a></li>
              <li><a href="/blog/manifesto" class="text-[13px] text-[#6a6a6a] hover:text-[#1a1a1a] transition-colors">Manifesto</a></li>
            </ul>
          </div>

          <!-- community -->
          <div>
            <div class="text-[11px] font-semibold uppercase tracking-[0.6px] text-[#1a1a1a] mb-[14px]">Community</div>
            <ul class="space-y-[10px]">
              <li><a href={GH} target="_blank" rel="noopener" class="text-[13px] text-[#6a6a6a] hover:text-[#1a1a1a] transition-colors">GitHub</a></li>
              <li><a href={DISCORD} target="_blank" rel="noopener" class="text-[13px] text-[#6a6a6a] hover:text-[#1a1a1a] transition-colors">Discord</a></li>
            </ul>
          </div>

          <!-- company -->
          <div>
            <div class="text-[11px] font-semibold uppercase tracking-[0.6px] text-[#1a1a1a] mb-[14px]">Company</div>
            <ul class="space-y-[10px]">
              <li><a href="https://www.responsive.dev" target="_blank" rel="noopener" class="text-[13px] text-[#6a6a6a] hover:text-[#1a1a1a] transition-colors">About us</a></li>
            </ul>
          </div>
        </div>
      </div>
    </footer>
  </div>
</LandingLayout>

<style is:global>
  html { scroll-behavior: smooth; }
  @keyframes pulseBlink { 0%, 100% { opacity: 0.3 } 50% { opacity: 1 } }
  .fam-anim { animation: pulseBlink 1.4s ease-in-out infinite; }

  /* Diagram scales to fit its container at every breakpoint (never scrolls):
     each cqi factor is tuned to the diagram's char width (vertical 74, horizontal
     61) so it stays within the container, capped at 13px so it never grows past
     its intended size. overflow:hidden is a belt-and-suspenders guard against any
     sub-pixel rounding overflow. */
  .fam-diag { container-type: inline-size; overflow: hidden; }
  #family-diagram { font-size: min(13px, 2.2cqi); }
  #family-diagram-h { font-size: min(13px, 2.7cqi); }
  /* The family section swaps between two layouts at a single breakpoint (1100px):
     at/above it the diagram sits side-by-side with the dialog (two columns,
     vertical diagram); below it everything stacks (dialog under the horizontal
     2×2 diagram). 1100px is about as low as the swap can go before the fixed
     600px diagram column + min dialog width overflow the card. Every rule keyed
     to this swap uses 1100/1099 so they flip together. */
  .fam-grid {
    display: grid;
    grid-template-columns: 600px minmax(260px, 1fr);
    gap: 1.5rem;            /* tightened from the stacked 2.5rem so the dialog sits near the diagram */
    /* Center the dialog against the left column (heading + diagram = full card
       height), so it sits centered to the card rather than to the diagram. */
    align-items: center;
  }
  /* Below the breakpoint everything collapses to a single stacked column. */
  @media (max-width: 1099px) { .fam-grid { grid-template-columns: 1fr; gap: 2.5rem; } }

  /* Two diagram layouts toggled by breakpoint: vertical flow in the side-by-side
     view, horizontal 2×2 flow once the panel stacks below. Only one is ever
     displayed; both are kept in sync by family.client.ts. */
  .fam-pre { display: none; }
  @media (min-width: 1100px) { .fam-pre-v { display: inline-block; } }
  @media (max-width: 1099px) {
    .fam-diag { text-align: center; }
    .fam-pre-h { display: inline-block; }
  }

  /* Dialog: a subtle floating card — hairline border + soft drop shadow, with a
     thin blue accent on the edge facing the diagram (top while stacked on
     mobile, left once side-by-side on desktop) tying it to the selected box. */
  .fam-panel {
    border: 1px solid rgba(20, 24, 40, .08);
    border-top: 3px solid #4971ab;
    box-shadow: 6px 6px 0 0 #d6d7d9;
    padding: 22px 22px 18px;
  }
  /* Product name as a compact tab sitting on the panel's top border. */
  .fam-title {
    position: absolute; top: -11px; left: 16px;
    background: #fff; padding: 0 8px;
    font-family: var(--font-mono); font-size: 13px; font-weight: 700; letter-spacing: .2px;
    color: #4971ab;
  }
  /* Stacked layout: tighter padding so the dialog isn't so tall. */
  @media (max-width: 1099px) { .fam-panel { padding: 16px 18px 14px; } }
  @media (min-width: 1100px) {
    .fam-panel { border: 1px solid rgba(20, 24, 40, .08); border-left: 3px solid #4971ab; }
    /* Dialog matches the diagram's height (26 rows × 13px = 338px) and is
       top-aligned with it. min-height (not height) so taller panels grow
       instead of clipping; the stacked layers keep every panel the same height. */
    #family-panel, #family-panel .fam-stack { min-height: 338px; }
    #family-panel .fam-layer,
    #family-panel .fam-panel { height: 100%; }
    /* Narrower, centered card at full size — shows more of the backdrop. The
       diagram column is fixed (600px), so the panel column (1fr) absorbs the
       trim; paired with the tighter column gap above it sits ~286px wide,
       closer to the diagram so the dialog reads as anchored, not adrift. */
    .float-card { max-width: 974px; margin-left: auto; margin-right: auto; }
  }

  /* Detail panel: all variants are rendered stacked in the same grid cell so
     the box always reserves the tallest one's height — switching never resizes
     it at any breakpoint. Only the active layer is visible (the rest stay
     laid out via visibility:hidden, which also blocks their interaction). */

  /* Framed sections: double border with a title tab */
  .abox { position: relative; border: 3px double #d0d0d0; background: #fff; padding: 48px 32px 40px; }
  .abox-title { position: absolute; top: -13px; left: 22px; background: #fff; padding: 0 10px; font-family: var(--font-sans); font-size: 16px; font-weight: 700; letter-spacing: .3px; color: #4971ab; }

  /* Borderless variant (why opendata): no frame, label flush-left. */
  .abox-bare { border: none; padding-left: 0; padding-right: 0; }
  .abox-bare .abox-title { left: 0; padding-left: 0; }

  /* Inline side label for the two-column "why opendata" layout (not the
     absolutely-positioned tab — sits in the left grid column). */
  .abox-title-side { font-family: var(--font-mono); font-size: 16px; font-weight: 700; letter-spacing: .3px; color: #4971ab; }

  /* Family frame: classical sketch as a backdrop, content floats on white cards.
     The image is bordered by a warm paper tone so it blends at the edges. */
  .abox-bg {
    background:
      linear-gradient(rgba(247, 243, 234, .35), rgba(247, 243, 234, .35)),
      url('/images/doric.png') center center / cover no-repeat,
      #f7f3ea;
    border-color: #cdbfa3;
    /* Horizontal padding scales up with viewport: tight on small/medium so the
       two-column layout has room, generous on wide screens to show more of the
       backdrop. (Tiered below.) */
    padding: 40px 24px 36px;
  }
  @media (min-width: 1024px) { .abox-bg { padding: 52px 48px 48px; } }
  @media (min-width: 1280px) { .abox-bg { padding: 56px 64px 52px; } }
  @media (max-width: 640px) { .abox-bg { padding: 32px 16px 28px; } }
  /* Floating white panels that sit above the backdrop */
  .float-card {
    position: relative;
    background: rgba(255, 255, 255, .94);
    backdrop-filter: blur(2px);
    -webkit-backdrop-filter: blur(2px);
    border: 1px solid rgba(0, 0, 0, .06);
    box-shadow: 0 10px 30px -8px rgba(40, 40, 60, .18), 0 2px 8px -2px rgba(40, 40, 60, .1);
    padding: 36px 32px;
  }
  /* Stacked layout: keep the card from stretching too wide; centered. */
  @media (max-width: 1099px) { .float-card { max-width: 720px; margin-left: auto; margin-right: auto; } }
  @media (max-width: 640px) { .float-card { padding: 24px 22px; } }
  .sec { max-width: 1280px; margin-left: auto; margin-right: auto; padding-left: 24px; padding-right: 24px; }
  .sec-family { padding-top: 16px; padding-bottom: 64px; }

  /* Lower half: section-label gutter. A fixed-width left column holds the
     right-aligned mono labels; a single vertical rule (border-left on the
     content column) runs continuously down through both rows, ending at the
     last section. The content keeps its original width and styling. */
  .lower { max-width: 1180px; margin-left: auto; margin-right: auto; padding: 12px 24px 48px; }
  .lower-row { display: grid; grid-template-columns: 200px minmax(0, 1fr); }
  /* A gap between the rows breaks the rule between sections: each content
     column's border ends with its own content, and this margin (outside both
     borders) leaves a clear break before the next section's rule resumes. */
  .lower-row + .lower-row { margin-top: 72px; }
  .lower-label {
    text-align: right;
    /* 32px top = the 28px the rule overhangs the content + a 4px optical
       nudge, so every label lines up with the top of its content. */
    padding: 32px 40px 0 0;
    font-family: var(--font-mono); font-size: 13px; font-weight: 700;
    line-height: 1.5; letter-spacing: 2px; text-transform: uppercase;
    color: #4971ab;
  }
  /* Stack the two words onto their own lines via block spans; the media query
     below switches them back to inline so they share one line when stacked. */
  .lower-label span { display: block; }
  /* The rule (border-left) overhangs its content by the same 28px at every end
     — top and bottom of both sections. Short feet (pseudo-elements) at each end
     point back toward the label gutter, turning the rule into a ] bracket. */
  .lower-content { position: relative; border-left: 1px solid #e4e4e4; padding: 28px 0 28px 56px; }
  .lower-content::before,
  .lower-content::after {
    content: ""; position: absolute; left: -11px; width: 11px; height: 1px; background: #e4e4e4;
  }
  .lower-content::before { top: 0; }
  .lower-content::after { bottom: 0; }

  @media (max-width: 900px) {
    /* Stack: label becomes a left-aligned eyebrow above its content, and the
       vertical bracket gives way to a horizontal rule between the sections. */
    .lower-row { grid-template-columns: 1fr; }
    .lower-label { text-align: left; padding: 0 0 12px 0; }
    .lower-label span { display: inline; }
    .lower-content { border-left: none; padding-top: 0; padding-left: 0; padding-bottom: 32px; }
    .lower-content::before, .lower-content::after { display: none; }
    .lower-row + .lower-row { margin-top: 0; padding-top: 32px; border-top: 1px solid #e4e4e4; }
  }

  /* Three pillars: stacked on small screens, a three-up row once there's room.
     Each card matches the family dialog — hairline border, a blue accent on the
     left edge, and the same offset drop shadow — so the trio reads as structured
     benefits that share the page's visual language. */
  .why-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 22px;
    margin-bottom: 30px;
  }
  @media (min-width: 640px) { .why-grid { grid-template-columns: repeat(3, 1fr); gap: 24px; } }
  .why-pillar {
    position: relative;
    background: #fff;
    border: 1px solid rgba(20, 24, 40, .08);
    border-left: 3px solid #4971ab;
    box-shadow: 6px 6px 0 0 #d6d7d9;
    padding: 20px 18px 16px;
  }
  /* Number sits as a tab on the top border, like the dialog's title tab. */
  .why-pillar-n {
    position: absolute; top: -9px; left: 14px;
    background: #fff; padding: 0 6px;
    font-family: var(--font-mono); font-size: 12px; font-weight: 700; letter-spacing: .5px; color: #4971ab;
  }
  .why-pillar-h { font-family: var(--font-sans); font-size: 14px; font-weight: 700; line-height: 1.35; color: #1a1a1a; }
  .why-pillar-p { margin-top: 8px; font-size: 13px; line-height: 1.6; color: #6a6a6a; }

  /* Install terminal: a mock terminal window with the pantheon backdrop and
     CSS-only tabs that swap the visible curl command. */
  /* The pantheon backdrop spans the whole window; the header sits over it and
     blurs its slice, the body shows it through a light scrim. */
  .term {
    position: relative;
    border: 1px solid rgba(20, 24, 40, .12);
    box-shadow: 6px 6px 0 0 #d6d7d9;
    background:
      linear-gradient(rgba(247, 243, 234, .78), rgba(247, 243, 234, .78)),
      url('/images/pantheon.png') center center / cover no-repeat,
      #f7f3ea;
    overflow: hidden;
  }
  /* Radios drive the tabs; hidden but kept in flow for label association. */
  .term-radio { position: absolute; opacity: 0; pointer-events: none; }
  /* Title/tab bar: translucent so the backdrop bleeds in, blurred for a frosted
     header over the image. */
  .term-bar {
    display: flex; align-items: stretch; gap: 14px;
    padding: 0 12px;
    background: rgba(236, 231, 219, .55);
    backdrop-filter: blur(7px);
    -webkit-backdrop-filter: blur(7px);
    border-bottom: 1px solid rgba(20, 24, 40, .12);
  }
  .term-dots { display: inline-flex; align-items: center; gap: 6px; flex: none; }
  .term-dots i { width: 11px; height: 11px; border-radius: 50%; background: #cdbfa3; }
  .term-dots i:nth-child(1) { background: #d98c7a; }
  .term-dots i:nth-child(2) { background: #d9c27a; }
  .term-dots i:nth-child(3) { background: #9fb08a; }
  .term-tabs { display: flex; align-self: stretch; }
  /* Tabs fill the full header height. */
  .term-tab {
    display: flex; align-items: center;
    font-family: var(--font-mono); font-size: 12px; font-weight: 500;
    color: #6a6a6a; cursor: pointer;
    padding: 9px 14px;
    border-left: 1px solid transparent; border-right: 1px solid transparent;
    transition: color .15s ease, background .15s ease;
  }
  .term-tab:hover { color: #1a1a1a; }
  /* Active tab styling, keyed off each radio's :checked state. */
  #term-log:checked ~ .term-bar .term-tab[for="term-log"],
  #term-timeseries:checked ~ .term-bar .term-tab[for="term-timeseries"],
  #term-vector:checked ~ .term-bar .term-tab[for="term-vector"],
